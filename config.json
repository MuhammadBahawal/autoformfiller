{
  "adspower": {
    "base_url": "http://local.adspower.net:50325",
    "api_key": "",
    "use_active_profiles": true,
    "profile_ids": [],
    "keep_browser_open": false
  },
  "excel": {
    "path": "D:/autoformfiller/data.xlsx",
    "sheet_name": "Sheet1",
    "header_row": 1,
    "first_data_row": 2,
    "skip_statuses": [
      "DONE",
      "FAILED"
    ],
    "status_column": "__status",
    "message_column": "__message",
    "processed_at_column": "__processed_at",
    "profile_column": "__profile_id"
  },
  "form": {
    "use_existing_page": true,
    "tab_index": -1,
    "target_url_contains": "stimulusassistforall.com/index-v8-form.php",
    "url": "",
    "page_load_timeout_seconds": 30,
    "field_timeout_seconds": 15,
    "post_submit_wait_seconds": 3,
    "submit_transition_wait_seconds": 6,
    "handle_surveys_after_submit": true,
    "survey_max_pages": 12,
    "survey_retry_count": 2,
    "survey_step_wait_seconds": 1.5,
    "return_to_form_before_each_row": true,
    "history_recover_max_steps": 3,
    "submit_after_fill": true,
    "submit_selector": "id=submit-btn",
    "success_wait_selector": "",
    "zip_step": {
      "enabled": false,
      "field_columns": [
        "ZIP"
      ],
      "next_selectors": [],
      "next_keywords": [
        "next",
        "continue",
        "proceed"
      ],
      "detection_wait_seconds": 1.5,
      "after_fill_wait_seconds": 0.75,
      "action_ready_wait_seconds": 5,
      "advance_retry_count": 3,
      "retry_pause_seconds": 1,
      "transition_wait_seconds": 15
    },
    "checkboxes": [
      {
        "selector": "id=form-optin",
        "checked": true
      }
    ]
  },
  "worker": {
    "retry_count": 1,
    "max_rows_per_profile": 1
  },
  "fields": [
    {
      "column": "FIRST",
      "type": "text",
      "selectors": [
        "id=first"
      ]
    },
    {
      "column": "LAST",
      "type": "text",
      "selectors": [
        "id=last"
      ]
    },
    {
      "column": "ADDRESS",
      "type": "text",
      "selectors": [
        "id=address"
      ]
    },
    {
      "column": "ZIP",
      "type": "text",
      "selectors": [
        "id=zip"
      ]
    },
    {
      "column": "EMAIL",
      "type": "text",
      "selectors": [
        "id=email"
      ]
    },
    {
      "column": "PHONE",
      "type": "text",
      "selectors": [
        "id=phone"
      ]
    },
    {
      "column": "DOB",
      "transform": "date_month_number",
      "type": "select_text",
      "selectors": [
        "id=birth_month"
      ]
    },
    {
      "column": "DOB",
      "transform": "date_day_number",
      "type": "select_text",
      "selectors": [
        "id=birth_day"
      ]
    },
    {
      "column": "DOB",
      "transform": "date_year",
      "type": "select_text",
      "selectors": [
        "id=birth_year"
      ]
    },
    {
      "column": "GENDER",
      "excel_column_letter": "H",
      "type": "hidden_text",
      "selectors": [
        "id=gender"
      ]
    },
    {
      "column": "CITY",
      "excel_column_letter": "I",
      "type": "hidden_text",
      "selectors": [
        "id=city"
      ]
    },
    {
      "column": "STATE",
      "excel_column_letter": "J",
      "type": "hidden_text",
      "selectors": [
        "id=state"
      ]
    }
  ]
}
